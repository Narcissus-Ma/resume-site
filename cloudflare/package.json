{
  "name": "resume-cloudflare-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --persist-to .wrangler/state",
    "test": "vitest run tests/*.test.ts && node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,mjs --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "auth:hash": "node scripts/generate-password-hash.mjs",
    "seed:local": "node scripts/initialize-catalogs.mjs --local",
    "seed:remote": "node scripts/initialize-catalogs.mjs --remote",
    "backup:local": "node scripts/export-catalogs.mjs --local",
    "backup:remote": "node scripts/export-catalogs.mjs --remote",
    "restore:local": "node scripts/restore-catalogs.mjs --local",
    "restore:remote": "node scripts/restore-catalogs.mjs --remote",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.10.10",
    "@cloudflare/workers-types": "^4.20250615.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.0"
  },
  "packageManager": "pnpm@8.15.9"
}
